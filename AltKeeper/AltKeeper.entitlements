<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  CloudKit/iCloud entitlements are intentionally omitted for unsigned/sideload builds.
	  Free Apple ID provisioning (AltStore/Sideloadly) cannot grant these capabilities;
	  embedding them causes an immediate launch crash on device.
	  Re-add iCloud.com.altkeeper.app when building with a paid Developer Team.
	-->
</dict>
</plist>
